# BSV anchoring — server-side only, never exposed to the browser.
# Copy this file to .env.local and fill in a testnet WIF private key.
# Never commit a real key. Never use a mainnet key in this PoC.

BSV_NETWORK=test              # test | main (default: test)
BSV_PRIVATE_KEY=              # WIF-format testnet private key for the anchoring wallet
BSV_FEE_RATE=0.05             # satoshis per byte (default: 0.05)
